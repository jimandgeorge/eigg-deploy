# EIGG combined deployment — copy to `.env` and fill in. Used for compose interpolation.
# Generate secrets: openssl rand -base64 32  (NEXTAUTH/SECRET_KEY) · openssl rand -hex 32 (INTERNAL)

# ── EIGG Prevent (prevent.eigg.io) ───────────────────────────────────────────
PREVENT_DB_PASSWORD=CHANGE_ME_strong_db_password
PREVENT_NEXTAUTH_SECRET=CHANGE_ME_base64_32
PREVENT_INTERNAL_SECRET=CHANGE_ME_hex_32          # shared by Prevent frontend + backend
PREVENT_ADMIN_EMAIL=admin@eigg.io
PREVENT_ADMIN_PASSWORD=CHANGE_ME_admin_password
PREVENT_LLM_PROVIDER=mock                         # mock | anthropic
PREVENT_ANTHROPIC_API_KEY=
PREVENT_AUTH_PASSWORD=                             # optional shared-password login

# ── EIGG Investigate (investigate.eigg.io) ───────────────────────────────────
INVEST_SECRET_KEY=CHANGE_ME_base64_32
INVEST_DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST/db?sslmode=require   # Neon
INVEST_NEXTAUTH_SECRET=CHANGE_ME_base64_32
INVEST_LLM_PROVIDER=anthropic
INVEST_ANTHROPIC_API_KEY=
INVEST_AUTH_PASSWORD=                              # optional shared-password login

# ── Shared ───────────────────────────────────────────────────────────────────
RESEND_API_KEY=                                   # invite emails (Prevent); blank = stub
